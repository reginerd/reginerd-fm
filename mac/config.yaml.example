# RGNRD-FM Configuration
# Copy this file to mac/config.yaml and fill in your values.

# Plex server settings
plex:
  host: 192.168.1.27
  port: 32400
  token_env: PLEX_TOKEN          # Set PLEX_TOKEN in .env
  library_section: 1             # Music library section key
  music_prefix: /volume1/music   # Path prefix Plex uses on the NAS (Synology default)

# NAS mount path (where Plex music files are accessible on this machine)
nas_mount: /Volumes/music        # Adjust to your actual mount path

# LLM settings (Claude API)
llm:
  timeout: 60
  temperature: 0.8
  max_tokens: 300

# TTS — ElevenLabs (primary) + Kokoro (fallback)
tts:
  elevenlabs:
    voice_id_env: ELEVENLABS_VOICE_ID   # Set in .env after voice clone is ready
    api_key_env: ELEVENLABS_API_KEY
  kokoro:
    voice: "af_heart"                   # Fallback voice

# Icecast streaming server
icecast:
  host: localhost
  port: 8000
  mount: /stream
  source_password_env: RGNRD_SOURCE_PASSWORD

# API server for now-playing info
api:
  port: 8001

# Content generation
generation:
  segments_ahead: 10             # Keep this many talk segments ready
