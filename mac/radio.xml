<?xml version="1.0" encoding="UTF-8"?>
<!--
  WRIT-FM ezstream configuration
  Reads from a playlist file managed by the feeder.
  Send SIGHUP to reload the playlist after updates.
-->
<ezstream>
  <servers>
    <server>
      <hostname>localhost</hostname>
      <port>8000</port>
      <password>writ_source_2024</password>
      <tls>None</tls>
      <reconnect_attempts>0</reconnect_attempts>
    </server>
  </servers>

  <streams>
    <stream>
      <mountpoint>/stream</mountpoint>
      <format>Ogg</format>
      <encoder>oggenc-q8</encoder>
      <stream_name>WRIT-FM</stream_name>
      <stream_genre>Talk Radio</stream_genre>
      <stream_description>The frequency between frequencies</stream_description>
    </stream>
  </streams>

  <intakes>
    <intake>
      <!-- Playlist intake program: returns one filename per call and writes
           the active track to output/.current_track.txt. That file becomes
           the source of truth for both Icecast metadata (via stream_metadata.sh)
           and the now-playing API (via feeder.py). It also archives the
           previous track to {slot}/aired/ as a side effect. -->
      <type>program</type>
      <filename>mac/playlist_intake.py</filename>
      <shuffle>No</shuffle>
      <stream_once>No</stream_once>
    </intake>
  </intakes>

  <metadata>
    <!-- Called by ezstream with no args, "artist", or "title" — never with
         the file path. The script reads .current_track.txt (written by the
         playlist intake program) to know what's currently playing. -->
    <program>mac/stream_metadata.sh</program>
    <format_str>@a@ - @t@</format_str>
    <normalize_strings>Yes</normalize_strings>
    <no_updates>No</no_updates>
  </metadata>

  <decoders>
    <decoder>
      <name>ffmpeg-wav</name>
      <program>ffmpeg -v quiet -i @T@ -af loudnorm=I=-14:TP=-1.5:LRA=7,aresample=44100 -f s16le -acodec pcm_s16le -ar 44100 -ac 2 -</program>
      <file_ext>.wav</file_ext>
    </decoder>
    <decoder>
      <name>ffmpeg-flac</name>
      <program>ffmpeg -v quiet -i @T@ -af loudnorm=I=-16:TP=-1.5:LRA=11,afade=t=in:st=0:d=3,aresample=44100 -f s16le -acodec pcm_s16le -ar 44100 -ac 2 -</program>
      <file_ext>.flac</file_ext>
    </decoder>
  </decoders>

  <encoders>
    <encoder>
      <name>oggenc-q8</name>
      <format>Ogg</format>
      <program>oggenc -r -B 16 -C 2 -R 44100 --raw-endianness 0 -q 8 -t @M@ -</program>
    </encoder>
  </encoders>
</ezstream>
