# Copy this file to .env and fill in your values.
# Never commit .env to git.

# Plex API token — get from Plex Web > Account > Preferences > XML API
PLEX_TOKEN=

# ElevenLabs — get from elevenlabs.io/app/api-key
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=       # Set after voice clone is created (REG-128)

# Icecast source password — set to match icecast.xml
RGNRD_SOURCE_PASSWORD=
